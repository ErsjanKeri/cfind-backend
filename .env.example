# =============================================================================
# APP CONFIGURATION
# =============================================================================
APP_NAME=CompanyFinder Albania API
APP_URL=http://localhost:3000
API_PREFIX=/api
ENVIRONMENT=development

# =============================================================================
# DATABASE
# =============================================================================
# Local dev (matches docker-compose.yml):
DATABASE_URL=postgresql+asyncpg://companyfinder:companyfinder_dev_password@localhost:5432/companyfinder
# Production: set DATABASE_URL directly in DigitalOcean App Platform env vars

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS_REMEMBER=30

# =============================================================================
# CORS - Frontend URLs (comma-separated)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,https://www.cfind.ai,https://cfind.ai

# =============================================================================
# COOKIE CONFIGURATION
# =============================================================================
# For cross-subdomain cookies (www.cfind.ai + api.cfind.ai)
# Set to ".cfind.ai" in production (note the leading dot)
# Leave empty or omit for localhost development
COOKIE_DOMAIN=.cfind.ai

# =============================================================================
# EMAIL - ZeptoMail SMTP
# =============================================================================
SMTP_HOST=smtp.zeptomail.eu
SMTP_PORT=587
SMTP_USERNAME=emailapikey
SMTP_PASSWORD=your_zeptomail_api_key_here
EMAIL_FROM=noreply@cfind.ai
EMAIL_FROM_NAME=CompanyFinder Albania

# =============================================================================
# AWS S3 / DigitalOcean Spaces
# =============================================================================
AWS_REGION=fra1
AWS_ACCESS_KEY_ID=your_digitalocean_spaces_key
AWS_SECRET_ACCESS_KEY=your_digitalocean_spaces_secret
AWS_BUCKET_NAME=cfind
AWS_ENDPOINT=https://fra1.digitaloceanspaces.com

# =============================================================================
# CRON JOBS
# =============================================================================
CRON_SECRET=your_secure_random_string_here

# =============================================================================
# CURRENCY
# =============================================================================
EUR_TO_LEK_RATE=100.0

# =============================================================================
# AI AGENT (Gemini)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
AGENT_MAX_MESSAGES_PER_DAY=50
